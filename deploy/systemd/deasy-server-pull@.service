[Unit]
Description=Deasy server-pull deploy for %i
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
WorkingDirectory=/opt/deasy
ExecStart=/bin/bash /opt/deasy/scripts/server-pull-deploy.sh %i git
TimeoutStartSec=1800

[Install]
WantedBy=multi-user.target
